<mujoco>
    <compiler angle="radian" meshdir="meshes" autolimits="true" />
    <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast" density="0" viscosity="0" />
    <asset>
        <!-- 天空盒纹理 (已注释，使用 Genesis 默认天空) -->
        <!-- <texture type="skybox" file="sea.png" gridsize="3 4" gridlayout=".U..LFRB.D.." /> -->

        <!-- 地面纹理和材质 -->
        <texture name="floor_tex" type="2d" file="Concrete1.png" width="512" height="512" hflip="false" vflip="false" content_type="image/png"/>
        <material name="floor_mat" reflectance="0.03" texture="floor_tex" texrepeat="20 20" texuniform="false" specular="0.1" shininess="0.2" rgba="1 1 1 1" />    

        <!-- 竖直长方体材质 -->
        <material name="cube_mat" rgba="0.2 0.6 0.8 1" specular="0.2" shininess="0.3" />
        <!-- 平放长方体材质 -->
        <material name="flat_cube_mat" rgba="0.8 0.4 0.2 1" specular="0.2" shininess="0.3" />
        <!-- link小长方体材质（新增二级link用浅灰色区分）-->
        <material name="link_mat" rgba="0.5 0.5 0.5 1" specular="0.1" shininess="0.2" />
        <material name="link2_mat" rgba="0.7 0.7 0.7 1" specular="0.1" shininess="0.2" />

        <!-- 狗头表情纹理（严格遵循官方 2d 纹理规范） -->
        <texture name="face_tex" type="2d" file="dog_face.png" width="256" height="256" content_type="image/png" colorspace="sRGB" hflip="false" vflip="false" nchannel="3" />       
        <!-- 绑定表情纹理到狗头材质 -->
        <material name="head_mat" texture="face_tex" texrepeat="1 1" texuniform="false" specular="0.2" shininess="0.3" rgba="0.6 0.4 0.2 1" /> 

    </asset>

    <worldbody>
        <!-- <geom name="floor" \/> -->
        <light directional="true" ambient=".3 .3 .3" pos="30 30 30" dir="0 -.5 -1" diffuse=".5 .5 .5" specular=".5 .5 .5" />

        <!-- 平放长方体 30cm×20cm×4cm -->
        <body name="flat_cube" pos="0 0 0.52"> 
        <freejoint/>
            <geom name="flat_cube_geom" type="box" size="0.14 0.075 0.02" material="flat_cube_mat" mass="0.2" condim="3"/>

            <site name="imu_site" pos="0 0 0" quat="1 0 0 0" size="0.01 0.01 0.01" rgba="1 0 0 0.5"/>

            <!--狗头-->
            <body name="dog_head" pos="0.14 0 0.06">
                <geom name="head_geom" type="box" size="0.04 0.04 0.04" material="head_mat" mass="0.05" condim="3" euler="1.5708 1.5708 0" />
            </body>

            <body name="h_back_right" pos="-0.14 -0.075 -0.08">
                <joint type="hinge" name="h_back_right" pos="0 0 0.045" axis="0 1 0" 
                       damping="0.1" frictionloss="0.01" stiffness="0" 
                      range="-1.57 1.57" limited="true" armature="0.02" />
                <geom name="link1_geom" type="capsule" size="0.015 0.045"  euler="0 0 0" material="link_mat" mass=".1" condim="3"/>
                
                <body name="l_back_right" pos="0 0 -0.12315">
                    <joint type="hinge" name="l_back_right" pos="0 0 0.06315" axis="0 1 0" 
                           damping="0.1" frictionloss="0.01" stiffness="0" 
                          range="-3.1416 0" limited="true" armature="0.02" />
                    <geom name="link1_2_geom" type="capsule" size="0.01 0.05315" material="link2_mat" mass=".1" condim="3"/>
                </body>
            </body>

            <body name="h_front_right" pos="0.14 -0.075 -0.08">
                <joint type="hinge" name="h_front_right" pos="0 0 0.045" axis="0 1 0" 
                       damping="0.1" frictionloss="0.01" stiffness="0" 
                      range="-1.57 1.57" limited="true" armature="0.02" />
                  <geom name="link2_geom" type="capsule" size="0.015 0.045" material="link_mat" mass=".1" condim="3"/>
                
                <body name="l_front_right" pos="0 0 -0.12315">
                    <joint type="hinge" name="l_front_right" pos="0 0 0.06315" axis="0 1 0" 
                           damping="0.1" frictionloss="0.01" stiffness="0" 
                          range="-3.1416 0" limited="true" armature="0.02" />
                      <geom name="link2_2_geom" type="capsule" size="0.01 0.05315" material="link2_mat" mass=".1" condim="3"/>
                </body>
            </body>

            <body name="h_back_left" pos="-0.14 0.075 -0.08">
                <joint type="hinge" name="h_back_left" pos="0 0 0.045" axis="0 1 0" 
                       damping="0.1" frictionloss="0.01" stiffness="0" 
                      range="-1.57 1.57" limited="true" armature="0.02" />
                  <geom name="link3_geom" type="capsule" size="0.015 0.045" material="link_mat" mass=".1" condim="3"/>
                
                <body name="l_back_left" pos="0 0 -0.12315">
                    <joint type="hinge" name="l_back_left" pos="0 0 0.06315" axis="0 1 0" 
                           damping="0.1" frictionloss="0.01" stiffness="0" 
                          range="-3.1416 0" limited="true" armature="0.02" />
                      <geom name="link3_2_geom" type="capsule" size="0.01 0.05315" material="link2_mat" mass=".1" condim="3"/>
                </body>
            </body>

            <body name="h_front_left" pos="0.14 0.075 -0.08">
                <joint type="hinge" name="h_front_left" pos="0 0 0.045" axis="0 1 0" 
                       damping="0.1" frictionloss="0.01" stiffness="0" 
                      range="-1.57 1.57" limited="true" armature="0.02" />
                  <geom name="link4_geom" type="capsule" size="0.015 0.045" material="link_mat" mass=".1" condim="3"/>
                
                <body name="l_front_left" pos="0 0 -0.12315">
                    <joint type="hinge" name="l_front_left" pos="0 0 0.06315" axis="0 1 0" 
                           damping="0.1" frictionloss="0.01" stiffness="0" 
                          range="-3.1416 0" limited="true" armature="0.02" />
                      <geom name="link4_2_geom" type="capsule" size="0.01 0.05315" material="link2_mat" mass=".1" condim="3"/>
                </body>
            </body>
        </body>
    </worldbody>

    <sensor>
        <!-- 机身姿态四元数 -->
        <framequat name="imu_quat" objtype="site" objname="imu_site" />
        <!-- 陀螺仪（角速度） -->
        <gyro name="imu_gyro" site="imu_site" noise="0.001" cutoff="100" />
        <!-- 加速度计（线性加速度，包含重力） -->
        <accelerometer name="imu_accel" site="imu_site" noise="0.01" cutoff="100" />
        <!-- 线速度 -->
        <framelinvel name="imu_linvel" objtype="site" objname="imu_site" />
    </sensor>

    <!-- 角度（位置）控制执行器：inheritrange now works -->
    <actuator>
        <position name="h_back_right_pos" joint="h_back_right" kp="30" dampratio="1" inheritrange="1.0"/>
        <position name="l_back_right_pos" joint="l_back_right" kp="30" dampratio="1" inheritrange="1.0"/>
        <position name="h_front_right_pos" joint="h_front_right" kp="30" dampratio="1" inheritrange="1.0"/>
        <position name="l_front_right_pos" joint="l_front_right" kp="30" dampratio="1" inheritrange="1.0"/>
        <position name="h_back_left_pos" joint="h_back_left" kp="30" dampratio="1" inheritrange="1.0"/>
        <position name="l_back_left_pos" joint="l_back_left" kp="30" dampratio="1" inheritrange="1.0"/>
        <position name="h_front_left_pos" joint="h_front_left" kp="30" dampratio="1" inheritrange="1.0"/>
        <position name="l_front_left_pos" joint="l_front_left" kp="30" dampratio="1" inheritrange="1.0"/>
    </actuator>
</mujoco>